**/build/
**/target/

# IDE/Editor files
**/.vscode/
**/.idea/
**/*.swp
**/*.swo
**/*.tmp

# System files
**/.DS_Store
**/Thumbs.db
**/.env
**/.env.local
**/*.env.*

# Logs and coverage
**/*.log
**/coverage/
**/htmlcov/
**/.coverage

# Compressed files
**/*.zip
**/*.gz
**/*.tar
**/*.tgz
**/*.bz2
**/*.xz
**/*.7z
**/*.rar
**/*.zst
**/*.lz4
